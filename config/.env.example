# Reference for environment variables. Copy relevant vars to ~/.fin/data/.env,
# or configure via App Settings → AgentMail API Key (packaged app).
# .env files in data/ are gitignored; this file is committed.

# AgentMail credentials for outbound alert emails.
# If either is unset, background alert checks are skipped (no silent fires).
AGENTMAIL_API_KEY=        # AgentMail API key
FIN_AGENTMAIL_INBOX=      # AgentMail inbox id (e.g. agent_xxx@agentmail.to) — sender mailbox

# Optional: override the log directory. Defaults to ~/.fin/logs.
FIN_LOG_DIR=

# Optional: override the API bind address. Defaults to 127.0.0.1 (localhost only).
# FIN_HOST=0.0.0.0  # uncomment to expose API to LAN

# Optional: when set to 1/true/yes, /api/prices serves only cached values and
# never blocks on a live yfinance fetch. The background price_updater becomes
# the sole refresh path. Useful when yfinance is slow or rate-limiting.
# FIN_PRICES_CACHE_ONLY=1
