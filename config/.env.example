# Reference for environment variables used by fin.
#
# Bootstrap .env location (loaded before data directory is resolved):
#   macOS/Linux : ~/.fin/.env
#   Windows     : %APPDATA%\Fin\Fin\.env
#
# This location is fixed so that FIN_DATA_DIR (and other overrides) take effect
# on startup. Setting FIN_DATA_DIR inside data/.env had no effect in prior versions.
#
# On first run after upgrade, an existing data/.env is automatically copied to the
# new location. Verify the migrated file then delete the old one.
#
# Configure via App Settings → AgentMail API Key (packaged app), or edit the file directly.

# AgentMail credentials for outbound alert emails.
# If either is unset, background alert checks are skipped (no silent fires).
AGENTMAIL_API_KEY=        # AgentMail API key
FIN_AGENTMAIL_INBOX=      # AgentMail inbox id (e.g. agent_xxx@agentmail.to) — sender mailbox

# Optional: override the data directory. Defaults to ~/.fin/data (macOS/Linux) or %LOCALAPPDATA%\Fin\Fin (Windows).
FIN_DATA_DIR=

# Optional: override the log directory. Defaults to ~/.fin/logs (macOS/Linux) or %LOCALAPPDATA%\Fin\Fin\Logs (Windows).
FIN_LOG_DIR=

# Optional: override the API bind address. Defaults to 127.0.0.1 (localhost only).
# FIN_HOST=0.0.0.0  # uncomment to expose API to LAN

# Optional: when set to 1/true/yes, /api/prices serves only cached values and
# never blocks on a live yfinance fetch. The background price_updater becomes
# the sole refresh path. Useful when yfinance is slow or rate-limiting.
# FIN_PRICES_CACHE_ONLY=1
