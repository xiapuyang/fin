# Copy to .env and fill in real values. .env is gitignored; this file is committed.
# Every environment variable the app reads should be listed here with a one-line comment.

# AgentMail credentials for outbound alert emails.
# If either is unset, alert emails are skipped (alerts still fire and record to DB).
AGENTMAIL_API_KEY=        # AgentMail API key
FIN_AGENTMAIL_INBOX=      # AgentMail inbox id (e.g. agent_xxx@agentmail.to) — sender mailbox

# Optional: override the log directory. Defaults to <project>/logs.
FIN_LOG_DIR=
